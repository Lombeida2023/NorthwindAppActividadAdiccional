@model List<NorthwindApp.Models.CarritoItem>

@{
    ViewData["Title"] = "Mi Carrito";
}

<h2>Mi Carrito de Compras</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Tu carrito está vacío.
        <a asp-controller="Products" asp-action="Index" class="alert-link">Ver productos disponibles</a>
    </div>
}
else
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Producto</th>
                <th class="text-end">Precio Unitario</th>
                <th class="text-center">Cantidad</th>
                <th class="text-end">Subtotal</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td class="text-end">@item.UnitPrice.ToString("C")</td>
                    <td class="text-center">
                        <form asp-action="ActualizarCantidad" method="post" class="d-flex align-items-center justify-content-center gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="number" name="cantidad" value="@item.Quantity" min="1"
                                   class="form-control form-control-sm text-center" style="width:75px"
                                   required />
                            <button type="submit" class="btn btn-outline-secondary btn-sm">Actualizar</button>
                        </form>
                    </td>
                    <td class="text-end"><strong>@item.Subtotal.ToString("C")</strong></td>
                    <td class="text-center">
                        <form asp-action="Eliminar" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('¿Quitar este producto del carrito?')">Quitar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-success">
                <td colspan="2"><strong>Total de productos: @Model.Sum(i => i.Quantity) unidad(es)</strong></td>
                <td colspan="2" class="text-end">
                    <strong class="fs-5">TOTAL: @Model.Sum(i => i.Subtotal).ToString("C")</strong>
                </td>
                <td></td>
            </tr>
        </tfoot>
    </table>

    <div class="d-flex gap-2 mt-3">
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">Seguir comprando</a>
        <form asp-action="Confirmar" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-lg"
                    onclick="return confirm('¿Confirmar la compra de @Model.Count producto(s)?')">
                Confirmar Compra
            </button>
        </form>
    </div>
}
