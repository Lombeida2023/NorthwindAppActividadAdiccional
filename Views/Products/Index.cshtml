@model IEnumerable<NorthwindApp.Models.Product>

@{
    ViewData["Title"] = "Productos";
}

<h1>Productos</h1>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex flex-wrap gap-2 mb-3">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">Nuevo Producto</a>
        <a asp-action="Descontinuados" class="btn btn-outline-danger btn-sm">Descontinuados</a>
        <a asp-action="SinExistencias" class="btn btn-outline-dark btn-sm">Sin Existencias</a>
    }
    <a asp-action="MasCaros" class="btn btn-outline-secondary btn-sm">10 Más Caros</a>
    <a asp-action="BuscarPorNombre" class="btn btn-outline-secondary btn-sm">Buscar por Nombre</a>
    <a asp-action="PorCategoria" class="btn btn-outline-secondary btn-sm">Por Categoría</a>
    <a asp-action="PorProveedor" class="btn btn-outline-secondary btn-sm">Por Proveedor</a>
    <a asp-action="EnPedidos" class="btn btn-outline-secondary btn-sm">En Pedidos</a>
    <a asp-action="StockBajo" class="btn btn-outline-warning btn-sm">Stock Bajo</a>
    <a asp-action="MasComprados" class="btn btn-outline-info btn-sm">Más Comprados</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre del Producto</th>
            <th>Categoría</th>
            <th>Proveedor</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@(item.Category?.CategoryName ?? "—")</td>
                <td>@(item.Supplier?.CompanyName ?? "—")</td>
                <td>@item.UnitPrice?.ToString("C")</td>
                <td>
                    @if (item.UnitsInStock <= item.ReorderLevel)
                    {
                        <span class="badge bg-warning text-dark">@item.UnitsInStock</span>
                    }
                    else
                    {
                        @item.UnitsInStock
                    }
                </td>
                <td>
                    @if (User.IsInRole("Customer"))
                    {
                        if (item.UnitsInStock > 0)
                        {
                            <form asp-controller="Carrito" asp-action="Agregar" method="post" class="d-inline">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="number" name="cantidad" value="1" min="1" max="@item.UnitsInStock"
                                       class="form-control form-control-sm d-inline" style="width:65px" />
                                <button type="submit" class="btn btn-success btn-sm">+ Carrito</button>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Sin stock</span>
                        }
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-outline-info btn-sm">Ver</a>
                        <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-outline-primary btn-sm">Editar</a>
                        <a asp-action="IncrementarStock" asp-route-id="@item.ProductId" class="btn btn-outline-success btn-sm">+Stock</a>
                        <a asp-action="ReducirStock" asp-route-id="@item.ProductId" class="btn btn-outline-warning btn-sm">-Stock</a>
                        <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-outline-danger btn-sm">Eliminar</a>
                    }
                    @if (!User.IsInRole("Admin") && !User.IsInRole("Customer"))
                    {
                        <a asp-action="Details" asp-route-id="@item.ProductId">Ver</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
            </li>
        }
    </ul>
</nav>
<p class="text-muted">Página @ViewBag.Page de @ViewBag.TotalPages</p>
