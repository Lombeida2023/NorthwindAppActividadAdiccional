@model IEnumerable<NorthwindApp.Models.Order>

@{
    ViewData["Title"] = "Pedidos";
}

<h2>Pedidos Registrados</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Nuevo Pedido</a>
    <a asp-action="ComprasPorCliente" class="btn btn-outline-info">Compras por Cliente</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th># Orden</th>
            <th>Fecha</th>
            <th>Cliente / Comprador</th>
            <th>Empleado</th>
            <th>Productos</th>
            <th>Total</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var total = item.OrderDetails.Sum(od => od.UnitPrice * od.Quantity);
            <tr>
                <td><strong>#@item.OrderId</strong></td>
                <td>@item.OrderDate</td>
                <td>
                    @if (item.Customer != null)
                    {
                        @item.Customer.CompanyName
                    }
                    else if (!string.IsNullOrEmpty(item.ShipName))
                    {
                        <span>@item.ShipName <span class="badge bg-info">Online</span></span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td>@(item.Employee != null ? $"{item.Employee.FirstName} {item.Employee.LastName}" : "—")</td>
                <td>@item.OrderDetails.Count</td>
                <td><strong>@total.ToString("C")</strong></td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-outline-info btn-sm">Ver Detalle</a>
                    <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-outline-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<p class="text-muted">Total: @Model.Count() pedidos</p>
