@model NorthwindApp.Models.Order

@{
    ViewData["Title"] = $"Pedido #{Model.OrderId}";
    var total = Model.OrderDetails.Sum(od => od.UnitPrice * od.Quantity);
}

<h2>Detalle del Pedido <span class="text-primary">#@Model.OrderId</span></h2>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-dark text-white">Información del Pedido</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Fecha</dt>
                    <dd class="col-sm-7">@Model.OrderDate</dd>
                    @if (Model.RequiredDate.HasValue)
                    {
                        <dt class="col-sm-5">Fecha requerida</dt>
                        <dd class="col-sm-7">@Model.RequiredDate</dd>
                    }
                    @if (Model.ShippedDate.HasValue)
                    {
                        <dt class="col-sm-5">Fecha envío</dt>
                        <dd class="col-sm-7">@Model.ShippedDate</dd>
                    }
                    @if (Model.Freight.HasValue && Model.Freight > 0)
                    {
                        <dt class="col-sm-5">Flete</dt>
                        <dd class="col-sm-7">@Model.Freight.Value.ToString("C")</dd>
                    }
                    @if (Model.ShipViaNavigation != null)
                    {
                        <dt class="col-sm-5">Enviado por</dt>
                        <dd class="col-sm-7">@Model.ShipViaNavigation.CompanyName</dd>
                    }
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-dark text-white">Datos de Envío / Cliente</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Comprador</dt>
                    <dd class="col-sm-7">
                        @(Model.Customer?.CompanyName ?? Model.ShipName ?? "—")
                        @if (Model.ShipName != null && Model.Customer == null)
                        {
                            <span class="badge bg-info ms-1">Online</span>
                        }
                    </dd>
                    @if (Model.Employee != null)
                    {
                        <dt class="col-sm-5">Empleado</dt>
                        <dd class="col-sm-7">@Model.Employee.FirstName @Model.Employee.LastName</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.ShipAddress) && Model.ShipAddress != "Compra Online")
                    {
                        <dt class="col-sm-5">Dirección</dt>
                        <dd class="col-sm-7">@Model.ShipAddress</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.ShipCity))
                    {
                        <dt class="col-sm-5">Ciudad / País</dt>
                        <dd class="col-sm-7">@Model.ShipCity @Model.ShipCountry</dd>
                    }
                    <dt class="col-sm-5">Tipo</dt>
                    <dd class="col-sm-7">
                        @if (Model.Customer == null && Model.ShipName != null)
                        {
                            <span class="badge bg-success">Compra Online</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pedido Tradicional</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<h4>Productos del Pedido</h4>
@if (Model.OrderDetails.Any())
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Producto</th>
                <th>Precio Unitario</th>
                <th>Cantidad</th>
                <th>Descuento</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @{int i = 1;}
            @foreach (var od in Model.OrderDetails)
            {
                var subtotal = od.UnitPrice * od.Quantity * (decimal)(1 - od.Discount);
                <tr>
                    <td>@(i++)</td>
                    <td>@od.Product.ProductName</td>
                    <td>@od.UnitPrice.ToString("C")</td>
                    <td>@od.Quantity</td>
                    <td>@od.Discount.ToString("P0")</td>
                    <td><strong>@subtotal.ToString("C")</strong></td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-success">
                <td colspan="5"><strong>TOTAL DEL PEDIDO</strong></td>
                <td><strong class="fs-5">@total.ToString("C")</strong></td>
            </tr>
        </tfoot>
    </table>
}
else
{
    <div class="alert alert-warning">Este pedido no tiene productos asociados.</div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver a Pedidos</a>
    <a asp-action="Edit" asp-route-id="@Model.OrderId" class="btn btn-outline-primary">Editar</a>
</div>
